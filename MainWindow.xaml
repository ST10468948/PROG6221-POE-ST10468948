<Window x:Class="ChatBotGui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ChatBotGui"
        mc:Ignorable="d"
        Title="Cybersecurity Awareness Assistant" Height="600" Width="450" Background="Azure">
    <Grid>
        <TabControl Background="White" BorderBrush="#D1D5DB" Margin="10">

            <TabItem Header="Chatbot Assistant" FontSize="14" Padding="10,5">
                <Grid Margin="10">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="[ Awareness Assistant v2.0 ]" FontSize="18" Foreground="Cyan" HorizontalAlignment="Center" FontWeight="Bold"/>
                        <TextBlock x:Name="tbAsciiCanvas" FontFamily="Consolas" FontSize="8" Foreground="SkyBlue" HorizontalAlignment="Center" Margin="5"/>
                    </StackPanel>

                    <ScrollViewer x:Name="chatScroller" Grid.Row="1" Background="DarkSlateBlue" VerticalScrollBarVisibility="Auto" Margin="0,5">
                        <TextBlock x:Name="tbChatDisplay" Padding="10" Foreground="White" FontSize="13" TextWrapping="Wrap" FontFamily="Segoe UI"/>
                    </ScrollViewer>

                    <Grid Grid.Row="2" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="txtUserInput" Grid.Column="0" Height="35" Background="DarkSlateBlue" Foreground="White" BorderBrush="Aqua" 
                                 VerticalContentAlignment="Center" Padding="5" KeyDown="TxtUserInput_KeyDown" FontSize="13"/>

                        <Button x:Name="btnSend" Content="SEND" Grid.Column="1" Width="80" Margin="5,0,0,0" Background="Azure" 
                                Foreground="DarkSlateBlue" FontWeight="Bold" Click="BtnSend_Click"/>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Task Assistant" FontSize="14" Padding="10,5">
                <Grid Margin="15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="250"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,15,0">
                        <TextBlock Text="Create New Cyber Task" FontSize="16" FontWeight="Bold" Foreground="#1F2937" Margin="0,0,0,15"/>

                        <TextBlock Text="Task Title:" Margin="0,5,0,2" Foreground="#4B5563" FontWeight="SemiBold"/>
                        <TextBox x:Name="TxtTaskTitle" Height="30" VerticalContentAlignment="Center" BorderBrush="#D1D5DB" Margin="0,0,0,10"/>

                        <TextBlock Text="Description:" Margin="0,5,0,2" Foreground="#4B5563" FontWeight="SemiBold"/>
                        <TextBox x:Name="TxtTaskDesc" Height="60" TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Top" BorderBrush="#D1D5DB" Margin="0,0,0,10"/>

                        <TextBlock Text="Reminder (e.g., In 5 days):" Margin="0,5,0,2" Foreground="#4B5563" FontWeight="SemiBold"/>
                        <TextBox x:Name="TxtTaskReminder" Height="30" VerticalContentAlignment="Center" BorderBrush="#D1D5DB" Margin="0,0,0,20"/>

                        <Button x:Name="BtnAddTask" Content="Add Task" Height="35" Background="#2563EB" Foreground="White" FontWeight="Bold" BorderThickness="0" Click="BtnAddTask_Click"/>
                    </StackPanel>

                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <DataGrid x:Name="DgdTasks" Grid.Row="0" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single" GridLinesVisibility="Horizontal" BorderBrush="#D1D5DB" Background="White">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="40" />
                                <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="150" />
                                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="180" />
                                <DataGridTextColumn Header="Reminder" Binding="{Binding Reminder}" Width="100" />
                                <DataGridCheckBoxColumn Header="Done" Binding="{Binding IsComplete}" Width="50" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                            <Button x:Name="BtnMarkComplete" Content="Mark Complete" Width="130" Height="35" Background="#10B981" Foreground="White" FontWeight="Bold" BorderThickness="0" Margin="0,0,10,0" Click="BtnMarkComplete_Click"/>
                            <Button x:Name="BtnDeleteTask" Content="Delete Task" Width="110" Height="35" Background="#EF4444" Foreground="White" FontWeight="Bold" BorderThickness="0" Click="BtnDeleteTask_Click"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Cyber Quiz" FontSize="14" Padding="10,5">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,15">
                        <TextBlock Text="Cybersecurity Awareness Quiz" FontSize="18" FontWeight="Bold" Foreground="#1F2937" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
                            <TextBlock Text="Score: " FontSize="14" FontWeight="SemiBold" Foreground="#4B5563"/>
                            <TextBlock x:Name="LblLiveScore" Text="0/10" FontSize="14" FontWeight="Bold" Foreground="#2563EB"/>
                        </StackPanel>
                    </DockPanel>

                    <StackPanel x:Name="PnlQuizActive" Grid.Row="1">
                        <TextBlock x:Name="TxtQuestionBox" Text="Question text will load right here..." FontSize="15" FontWeight="SemiBold" TextWrapping="Wrap" Foreground="#374151" Margin="0,0,0,15"/>

                        <RadioButton x:Name="RadOptA" Content="Option A Text" FontSize="13" Margin="5,5,0,5" GroupName="QuizOptions"/>
                        <RadioButton x:Name="RadOptB" Content="Option B Text" FontSize="13" Margin="5,5,0,5" GroupName="QuizOptions"/>
                        <RadioButton x:Name="RadOptC" Content="Option C Text" FontSize="13" Margin="5,5,0,5" GroupName="QuizOptions"/>
                        <RadioButton x:Name="RadOptD" Content="Option D Text" FontSize="13" Margin="5,5,0,20" GroupName="QuizOptions"/>

                        <Button x:Name="BtnSubmitAnswer" Content="Submit Answer" Height="35" Width="140" HorizontalAlignment="Left" Background="#2563EB" Foreground="White" FontWeight="Bold" BorderThickness="0" Click="BtnSubmitAnswer_Click"/>
                    </StackPanel>

                    <StackPanel x:Name="PnlFeedback" Grid.Row="2" Margin="0,20,0,0" Visibility="Collapsed">
                        <Border BorderThickness="1" CornerRadius="5" Padding="12" x:Name="BdrFeedbackStatus">
                            <StackPanel>
                                <TextBlock x:Name="TxtFeedbackStatus" Text="Correct / Incorrect Status" FontSize="14" FontWeight="Bold" Margin="0,0,0,5"/>
                                <TextBlock x:Name="TxtExplanation" Text="Educational explanation text will display here..." FontSize="13" TextWrapping="Wrap" Foreground="#4B5563"/>
                            </StackPanel>
                        </Border>
                        <Button x:Name="BtnNextQuestion" Content="Next Question" Height="35" Width="140" HorizontalAlignment="Left" Margin="0,15,0,0" Background="#10B981" Foreground="White" FontWeight="Bold" BorderThickness="0" Click="BtnNextQuestion_Click"/>
                    </StackPanel>

                    <StackPanel x:Name="PnlQuizResults" Grid.Row="1" Grid.RowSpan="2" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,40,0,0">
                        <TextBlock Text="Quiz Completed!" FontSize="20" FontWeight="Bold" Foreground="#10B981" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock x:Name="TxtFinalScoreReport" Text="You scored 0 out of 10" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                        <TextBlock x:Name="TxtFinalFeedbackMsg" Text="Great job message goes here!" FontSize="14" Foreground="#4B5563" HorizontalAlignment="Center" Margin="0,0,0,25"/>
                        <Button x:Name="BtnRestartQuiz" Content="Try Again" Height="35" Width="120" Background="#4B5563" Foreground="White" FontWeight="Bold" BorderThickness="0" Click="BtnRestartQuiz_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Activity Log" FontSize="14" Padding="10,5">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="System Actions Ledger" FontSize="16" FontWeight="Bold" Foreground="#1F2937" Margin="0,0,0,5"/>
                    <TextBlock Grid.Row="1" Text="Monitors chatbot interactions, quiz completions, and task operations with strict system timestamps." FontSize="12" Foreground="#6B7280" TextWrapping="Wrap" Margin="0,0,0,15"/>

                    <ScrollViewer Grid.Row="2" Background="#F9FAFB" BorderBrush="#D1D5DB" BorderThickness="1" VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="TxtLogDisplay" Padding="10" Text="No actions logged yet." FontSize="13" Foreground="#374151" TextWrapping="Wrap" FontFamily="Consolas"/>
                    </ScrollViewer>

                    <Grid Grid.Row="3" Margin="0,15,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="BtnRefreshLog" Grid.Column="0" Content="Refresh Log" Width="110" Height="35" Background="#2563EB" Foreground="White" FontWeight="Bold" BorderThickness="0" Click="BtnRefreshLog_Click"/>

                        <Button x:Name="BtnShowMoreLog" Grid.Column="2" Content="Show More History" Width="150" Height="35" Background="#4B5563" Foreground="White" FontWeight="Bold" BorderThickness="0" Click="BtnShowMoreLog_Click"/>
                    </Grid>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>